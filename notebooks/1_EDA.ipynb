   "source": [
    "# 1. Imports and Data Loading\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f7bbb9bd-f83f-4e99-88b5-ee8468f52431",
   "metadata": {},
   "source": [
    "Load CSV File"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "dbcd9a3c-76e8-4c1d-b07b-c228039b1ed5",
   "metadata": {},
   "outputs": [],
   "source": [
    df = pd.read_csv('../medical_insurance.csv')
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "5fbca9dd-c36d-4b2b-93c2-33b5bbd66f39",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Drop Leakage Columns\n",
    "leakage_cols = [\n",
    "    \"person_id\", \"annual_premium\", \"monthly_premium\", \"total_claims_paid\", \n",
    "    \"avg_claim_amount\", \"claims_count\", \"risk_score\", \"proc_imaging_count\", \n",
    "    \"proc_surgery_count\", \"proc_physio_count\", \"proc_consult_count\", \n",
    "    \"proc_lab_count\", \"had_major_procedure\"\n",
    "]\n",
    "df_clean = df.drop(columns=leakage_cols)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "bca30b49-1b02-4f64-9d6c-f308c1be6d91",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--- Alcohol Frequency Distribution ---\n",
      "alcohol_freq\n",
      "Occasional    45.078\n",
      "Unknown       30.083\n",
      "Weekly        19.833\n",
      "Daily          5.006\n",
      "Name: proportion, dtype: float64\n"
     ]
    }
   ],
   "source": [
    "# 3. Handle Missing Values & Distribution Check\n",
    "df_clean['alcohol_freq'] = df_clean['alcohol_freq'].fillna('Unknown')\n",
    "print(\"--- Alcohol Frequency Distribution ---\")\n",
    "print(df_clean['alcohol_freq'].value_counts(normalize=True) * 100)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "b1ec1d13-a8e4-4961-b97f-f5439deb69de",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. Feature Engineering: MAP and Log Cost\n",
    "df_clean['MAP'] = (2 * df_clean['diastolic_bp'] + df_clean['systolic_bp']) / 3\n",
    "df_clean['log_cost'] = np.log1p(df_clean['annual_medical_cost'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "20f23fa5-64f4-4f6d-9ad3-6263b519f67f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "--- Blood Pressure vs Cost Correlation ---\n",
      "Systolic: 0.1451\n",
      "Diastolic: 0.1176\n",
      "MAP: 0.1530\n"
     ]
    }
   ],
   "source": [
    "# Print MAP justification before dropping raw BP\n",
    "print(\"\\n--- Blood Pressure vs Cost Correlation ---\")\n",
    "print(f\"Systolic: {df_clean['systolic_bp'].corr(df_clean['annual_medical_cost']):.4f}\")\n",
    "print(f\"Diastolic: {df_clean['diastolic_bp'].corr(df_clean['annual_medical_cost']):.4f}\")\n",
    "print(f\"MAP: {df_clean['MAP'].corr(df_clean['annual_medical_cost']):.4f}\")\n",
    "\n",
    "df_clean.drop(columns=['systolic_bp', 'diastolic_bp'], inplace=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "df604bb6-0a8a-4d9c-ad3a-8a353b34ac34",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1800x500 with 3 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# 5. Target Distribution & Outliers\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18,5))\n",
    "sns.boxplot(x=df_clean['annual_medical_cost'], ax=axes[0])\n",
    "axes[0].set_title(\"Outlier Detection (Raw Cost)\")\n",
    "sns.histplot(df_clean['annual_medical_cost'], bins=50, kde=True, ax=axes[1])\n",
    "axes[1].set_title(\"Raw Cost Distribution\")\n",
    "sns.histplot(df_clean['log_cost'], bins=50, kde=True, ax=axes[2])\n",
    "axes[2].set_title(\"Log-Transformed Cost Distribution\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "32a5f74c-9736-4466-a4f3-21f296292d43",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "--- Model A Features (Baseline Health) ---\n",
      "chronic_count    0.296720\n",
      "is_high_risk     0.251923\n",
      "MAP              0.153031\n",
      "age              0.131166\n",
      "hba1c            0.083416\n",
      "bmi              0.043198\n",
      "Name: annual_medical_cost, dtype: float64\n",
      "\n",
      "--- Model B Features (Utilization) ---\n",
      "days_hospitalized_last_3yrs    0.230246\n",
      "hospitalizations_last_3yrs     0.208640\n",
      "visits_last_year               0.195631\n",
      "Name: annual_medical_cost, dtype: float64\n"
     ]
    }
   ],
   "source": [
    "# 6. Tiered Correlation Analysis (Raw Scale for Interpretability)\n",
    "numeric_df = df_clean.select_dtypes(include=[np.number])\n",
    "correlations = numeric_df.corr()['annual_medical_cost']\n",
    "\n",
    "print(\"\\n--- Model A Features (Baseline Health) ---\")\n",
    "model_a_cols = ['chronic_count', 'is_high_risk', 'MAP', 'age', 'bmi', 'hba1c']\n",
    "print(correlations[model_a_cols].sort_values(ascending=False))\n",
    "\n",
    "print(\"\\n--- Model B Features (Utilization) ---\")\n",
    "model_b_cols = ['days_hospitalized_last_3yrs', 'hospitalizations_last_3yrs', 'visits_last_year']\n",
    "print(correlations[model_b_cols].sort_values(ascending=False))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "0ddd591a-6475-4412-ab6f-7bb6f5c45273",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x500 with 2 Axes>"
      ]
     },
