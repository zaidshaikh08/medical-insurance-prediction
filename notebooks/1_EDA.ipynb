   ],
   "source": [
    "# 7. Visual Relationships: Density vs Spread\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "sample_df = df_clean.sample(5000, random_state=42)\n",
    "axes[0].hexbin(df_clean['age'], df_clean['log_cost'], gridsize=30, cmap='Blues', mincnt=1)\n",
    "axes[0].set_title(\"Age vs Log Cost (Density - Full Data)\")\n",
    "axes[0].set_xlabel(\"Age\")\n",
    "axes[0].set_ylabel(\"Log Cost\")\n",
    "\n",
    "# Scatter for outliers\n",
    "sns.scatterplot(x='age', y='log_cost', data=sample_df, alpha=0.4, ax=axes[1])\n",
    "axes[1].set_title(\"Age vs Log Cost (Spread - 5k Sample)\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "cfe8ca0b-1657-4926-b35e-1acb04a390de",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x500 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# 8. Utilization & Socioeconomic Impact\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Utilization\n",
    "sns.boxplot(x='hospitalizations_last_3yrs', y='log_cost', data=df_clean, ax=axes[0])\n",
    "axes[0].set_title(\"Hospitalizations vs Log Cost\")\n",
    "\n",
    "# Income Quartiles\n",
    "df_clean['income_quartile'] = pd.qcut(df_clean['income'], 4, labels=['Q1 (Low)', 'Q2', 'Q3', 'Q4 (High)'])\n",
    "sns.boxplot(x='income_quartile', y='log_cost', data=df_clean, ax=axes[1])\n",
    "axes[1].set_title(\"Income Quartiles vs Log Cost\")\n",
    "plt.show()"
   ]
  },
